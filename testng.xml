<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="PetStore API Test Suite" parallel="tests" thread-count="3">
    
    <!-- Pet Module Tests -->
    <test name="Pet - Add Pet Tests">
        <classes>
            <class name="petstore.pet.PostAddPetTests"/>
        </classes>
    </test>
    
    <test name="Pet - Update Pet Tests">
        <classes>
            <class name="petstore.pet.PutUpdatePetTests"/>
        </classes>
    </test>
    
    <test name="Pet - Find Pets By Status Tests">
        <classes>
            <class name="petstore.pet.GetFindPetsByStatusTests"/>
        </classes>
    </test>
    
    <test name="Pet - Find Pets By Tags Tests">
        <classes>
            <class name="petstore.pet.GetFindPetsByTagsTests"/>
        </classes>
    </test>
    
    <test name="Pet - Get Pet By ID Tests">
        <classes>
            <class name="petstore.pet.GetPetByIdTests"/>
        </classes>
    </test>
    
    <test name="Pet - Update Pet With Form Tests">
        <classes>
            <class name="petstore.pet.PostUpdatePetWithFormTests"/>
        </classes>
    </test>
    
    <test name="Pet - Delete Pet Tests">
        <classes>
            <class name="petstore.pet.DeletePetTests"/>
        </classes>
    </test>
    
    <test name="Pet - Upload Image Tests">
        <classes>
            <class name="petstore.pet.UploadImageTests"/>
        </classes>
    </test>
    
    <!-- Store Module Tests -->
    <test name="Store - Get Inventory Tests">
        <classes>
            <class name="petstore.store.GetInventoryTests"/>
        </classes>
    </test>
    
    <test name="Store - Place Order Tests">
        <classes>
            <class name="petstore.store.PostPlaceOrderTests"/>
        </classes>
    </test>
    
    <test name="Store - Get Order By ID Tests">
        <classes>
            <class name="petstore.store.GetOrderByIdTests"/>
        </classes>
    </test>
    
    <test name="Store - Delete Order Tests">
        <classes>
            <class name="petstore.store.DeleteOrderTests"/>
        </classes>
    </test>
    
    <!-- User Module Tests -->
    <test name="User - Create User Tests">
        <classes>
            <class name="petstore.user.PostCreateUserTests"/>
        </classes>
    </test>
    
    <test name="User - Create Users With Array Tests">
        <classes>
            <class name="petstore.user.PostCreateUsersWithArrayTests"/>
        </classes>
    </test>
    
    <test name="User - Create Users With List Tests">
        <classes>
            <class name="petstore.user.PostCreateUsersWithListTests"/>
        </classes>
    </test>
    
    <test name="User - Get User By Name Tests">
        <classes>
            <class name="petstore.user.GetUserByNameTests"/>
        </classes>
    </test>
    
    <test name="User - Update User Tests">
        <classes>
            <class name="petstore.user.PutUpdateUserTests"/>
        </classes>
    </test>
    
    <test name="User - Delete User Tests">
        <classes>
            <class name="petstore.user.DeleteUserTests"/>
        </classes>
    </test>
    
    <test name="User - Login User Tests">
        <classes>
            <class name="petstore.user.GetLoginUserTests"/>
        </classes>
    </test>
    
    <test name="User - Logout User Tests">
        <classes>
            <class name="petstore.user.GetLogoutUserTests"/>
        </classes>
    </test>
    
    <!-- Workflow Tests -->
    <test name="Workflows - Complete CRUD Workflow Tests">
        <classes>
            <class name="petstore.workflows.CompleteCRUDWorkflowTests"/>
        </classes>
    </test>
    
    <test name="Workflows - Authorization Workflow Tests">
        <classes>
            <class name="petstore.workflows.AuthorizationWorkflowTests"/>
        </classes>
    </test>
    
    <test name="Workflows - Data Consistency Workflow Tests">
        <classes>
            <class name="petstore.workflows.DataConsistencyWorkflowTests"/>
        </classes>
    </test>
    
    <!-- Listeners -->
    <listeners>
        <listener class-name="org.testng.reporters.EmailableReporter2"/>
        <listener class-name="org.testng.reporters.XMLReporter"/>
    </listeners>
    
</suite>